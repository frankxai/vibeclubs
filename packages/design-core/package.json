{
  "name": "@frankx/design-core",
  "version": "0.1.0",
  "description": "Shared design tokens, motion primitives, and theme scaffolding across frankx.ai / gencreator.ai / vibeclubs.ai / arcanea.ai. CSS var-first, framework-agnostic.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./motion.css": "./src/motion.css",
    "./themes/vibeclubs.css": "./src/themes/vibeclubs.css",
    "./themes/frankx.css": "./src/themes/frankx.css"
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
